# ═══════════════════════════════════════════
# Nexus — Configuration ($0 cost)
# ═══════════════════════════════════════════
# Switch provider: change LLM_PROVIDER
LLM_PROVIDER=groq

# Groq (recommended — free, 500 tok/s)
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Google Gemini (free backup)
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Ollama (offline only)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Embeddings (runs locally, no key)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Search
ARXIV_MAX_RESULTS=5
SCHOLAR_MAX_RESULTS=5
SEARCH_TIMEOUT_SECONDS=30

# Agent
MAX_CRITIC_REVISIONS=2

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=pretty

# LangSmith tracing (optional — set to enable observability)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=nexus-research-agent

# Light models (cheaper/faster for simple tasks like planning)
GROQ_MODEL_LIGHT=llama-3.1-8b-instant
GEMINI_MODEL_LIGHT=gemini-2.0-flash-lite
OLLAMA_MODEL_LIGHT=llama3.1:8b